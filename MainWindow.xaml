<Window x:Class="UP01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP01"
        xmlns:vm="clr-namespace:UP01.ViewModels"
        mc:Ignorable="d" Icon="/Images/icon.ico"
        Title="Главное окно" Height="550" Width="1000">

    <Window.DataContext>
        <vm:MainWindowVM/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="bx"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="0.6*"/>
            <RowDefinition Height="1.7*"/>
            <RowDefinition/>
            <RowDefinition Height="0.4*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.4*"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Image Source="/Images/icon.JPG" Grid.Column="0" Grid.Row="0"/>

        <Label Content="MegaToyShop" Style="{StaticResource MainLabelStyle}"
               Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
               Margin="5, 0, 0, 0" HorizontalAlignment="Left" FontSize="40"/>

        <Label Content="{Binding UserFullName, StringFormat=ФИО: {0}}"
               Grid.Row="0" Grid.ColumnSpan="2" Grid.Column="2" HorizontalAlignment="Right"
               VerticalAlignment="Top" x:Name="UsernameLabel" Margin="15"
               Style="{StaticResource MainLabelStyle}" FontSize="16"/>

        <StackPanel Orientation="Horizontal" Grid.Row="1"
                    Grid.ColumnSpan="3" Margin="10"
                    Visibility="{Binding IsAdmin, Converter={StaticResource bx}}">
            <Button Style="{StaticResource MainButtonStyle}"
                    Content="Добавить товар"
                    HorizontalAlignment="Left"
                    FontSize="20" Margin="5, 0"
                    x:Name="AddButton" Command="{Binding CommandAddProduct}"/>

            <Button Style="{StaticResource MainButtonStyle}"
                    Content="Изменить товар"
                    HorizontalAlignment="Left"
                    FontSize="20"
                    Margin="5, 0"
                    x:Name="EditButton" Command="{Binding CommandEditProduct}"/>

            <Button Style="{StaticResource MainButtonStyle}"
                    Content="Удалить товар"
                    HorizontalAlignment="Left"
                    FontSize="20"
                    Margin="5, 0"
                    x:Name="DeleteButton" Command="{Binding CommandDeleteProduct}"/>
        </StackPanel>

        <Button Content="Выход" Grid.Column="3"
                Grid.Row="4" Style="{StaticResource MainButtonStyle}"
                VerticalAlignment="Center" HorizontalAlignment="Right"
                Margin="5" FontSize="20" x:Name="ExitButton" Command="{Binding CommandExit}"/>

        <!--Область отображения данных-->
        <Border Grid.Row="2" Grid.ColumnSpan="4" Grid.RowSpan="2"
                CornerRadius="5" Background="Transparent"
                BorderBrush="Black" Margin="5, 0" BorderThickness="1">
            <ListView x:Name="ItemListView" HorizontalContentAlignment="Stretch"
                      ItemsSource="{Binding ProductsList}"
                      SelectedItem="{Binding SelectedProduct}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="5" Background="#F5DEB3" BorderBrush="Black"
                                BorderThickness="1">
                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="5*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>

                                <Image Source="{Binding Image}" Width="150" Height="150" Grid.Column="0"/>
                                <StackPanel Orientation="Vertical" Grid.Column="1" Margin="5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding ProductCategory}"/>
                                        <TextBlock Text=" | "/>
                                        <TextBlock Text="{Binding ProductName}"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Description, StringFormat={}Описание: {0}}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Manufacturer, StringFormat={}Производитель: {0}}"/>
                                    <TextBlock Text="{Binding Deliverer, StringFormat={}Поставщик: {0}}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock TextDecorations="{Binding DiscountDecor}"
                                                   Foreground="{Binding TextColor}"
                                                   Text="{Binding Cost}"/>
                                        <TextBlock Text=" "/>
                                        <TextBlock Text="{Binding DiscountPrice}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding EdIzm, StringFormat={}Единица измерения: {0}}"/>
                                    <TextBlock Text="{Binding AmountStored, StringFormat={}Количество на складе: {0}}"
                                               Foreground="{Binding AmountColor}"/>
                                </StackPanel>

                                <Border Grid.Column="2" Margin="5" CornerRadius="4" BorderThickness="1" BorderBrush="Black"
                                        Background="{Binding BackColor}">
                                    <TextBlock Text="{Binding CurrentDiscount, StringFormat={}Скидка: {0}%}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </Border>
    </Grid>
</Window>
